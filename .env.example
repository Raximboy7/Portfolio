# ============================================================================
#  .env namunasi — bu faylni ".env" deb nusxalang va qiymatlarni to'ldiring.
#  cp .env.example .env
# ============================================================================

# Django maxfiy kaliti (productionda ALBATTA o'zgartiring!)
# Yangi kalit: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-please-generate-a-new-secret-key

# Development uchun True, productionda False
DEBUG=True

# Vergul bilan ajratilgan domenlar
ALLOWED_HOSTS=ibrohimov-dev.uz,www.ibrohimov-dev.uz,localhost,127.0.0.1

# HTTPS POST (forma) uchun ishonchli manbalar
CSRF_TRUSTED_ORIGINS=https://ibrohimov-dev.uz,https://www.ibrohimov-dev.uz

# ----------------------------------------------------------------------------
#  Telegram bot — aloqa formasi xabarlari shu botga keladi.
#  1) @BotFather ga /newbot yozib bot yarating -> TOKEN olasiz.
#  2) Botingizga "/start" deb yozing.
#  3) Chat ID ni oling:  https://api.telegram.org/bot<TOKEN>/getUpdates
#     javobdagi "chat":{"id": ... } qiymatini quyiga yozing.
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Production HTTPS ga majburiy yo'naltirish (reverse proxy SSL bersa True)
SECURE_SSL_REDIRECT=False
